# --- Recommended: Client Credentials Grant (client_id + client_secret) ---
# Pick one subject: enterprise (typical for automation) or a specific user ID.
BOX_CLIENT_ID=
BOX_CLIENT_SECRET=
BOX_ENTERPRISE_ID=
# Optional alternative to BOX_ENTERPRISE_ID when you must act as a user:
# BOX_USER_ID=

# Optional: where to create/find the Raffle folder. Defaults to All Files root.
BOX_PARENT_FOLDER_ID=0

# Optional: defaults to "Raffle".
BOX_RAFFLE_FOLDER_NAME=Raffle

# Optional: uploader staging folder. Defaults to "Temp".
BOX_TEMP_FOLDER_NAME=Temp

# --- Optional dev fallback ---
# Short-lived developer token. Used only when CCG env above is incomplete
# (e.g. local testing with client id/secret + token exchange to the browser).
# BOX_ACCESS_TOKEN=
